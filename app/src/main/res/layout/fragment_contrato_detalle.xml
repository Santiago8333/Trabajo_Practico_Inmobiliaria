<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="24dp"
    android:background="#F5F5F5"
    tools:context=".ui.contratos.ContratoDetalleFragment">

    <TextView
        android:id="@+id/tvTituloDetalle"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Detalle del Contrato"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="#212121"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <androidx.cardview.widget.CardView
        android:id="@+id/cardDetalles"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="24dp"
        app:cardCornerRadius="12dp"
        app:cardElevation="4dp"
        app:contentPadding="20dp"
        app:layout_constraintTop_toBottomOf="@id/tvTituloDetalle">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha de Inicio"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvContratoFechaInicio"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="01/01/2026" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Fecha de Finalización"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvContratoFechaFinalizacion"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textColor="#212121"
                android:textSize="18sp"
                android:textStyle="bold"
                tools:text="31/12/2026" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Monto del Alquiler"
                android:textColor="#757575"
                android:textSize="14sp" />

            <TextView
                android:id="@+id/tvContratoMontoAlquiler"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="#388E3C"
                tools:text="$ 150.000" />

            <CheckBox
                android:id="@+id/cbDisponibleContrato"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Contrato Activo"
                android:textColor="?android:attr/textColorPrimary"
                android:textStyle="bold"
                android:clickable="false" />

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <com.google.android.material.button.MaterialButton
        android:id="@+id/btnVerPagos"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:layout_marginTop="32dp"
        android:text="VER PAGOS"
        android:textSize="16sp"
        android:textStyle="bold"
        android:enabled="false"
        app:cornerRadius="8dp"
        app:layout_constraintTop_toBottomOf="@id/cardDetalles"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent" />

</androidx.constraintlayout.widget.ConstraintLayout>