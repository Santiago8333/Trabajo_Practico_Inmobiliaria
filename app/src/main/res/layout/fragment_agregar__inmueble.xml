<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    tools:context=".ui.inmuebles.Agregar_InmuebleFragment">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="24dp">

        <TextView
            android:id="@+id/textView11"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:text="Agregar Inmueble"
            android:textAlignment="center"
            android:textColor="?android:attr/textColorPrimary"
            android:textSize="24sp"
            android:textStyle="bold" />

        <TextView
            android:id="@+id/textView15"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Dirección"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edDireccion"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:hint="Ej. Av. Universitaria 1024"
            android:inputType="textPostalAddress" />

        <TextView
            android:id="@+id/lblValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Valor"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edValor"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:hint="Ej. 150000"
            android:inputType="numberDecimal" />

        <TextView
            android:id="@+id/lblSuperficie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Superficie (m²)"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edSuperficie"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:hint="Ej. 120"
            android:inputType="number" />

        <TextView
            android:id="@+id/textView13"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Ambientes"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edAmbientes"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:hint="Ej. 3"
            android:inputType="number" />

        <TextView
            android:id="@+id/lblUso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Uso"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edUso"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="16dp"
            android:minHeight="48dp"
            android:hint="Ej. Residencial / Comercial"
            android:inputType="text" />

        <TextView
            android:id="@+id/lblTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Tipo"
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

        <EditText
            android:id="@+id/edTipo"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="32dp"
            android:hint="Ej. Departamento / Casa"
            android:minHeight="48dp"
            android:inputType="text" />

        <ImageView
            android:id="@+id/ivImagenInmueble"
            android:layout_width="match_parent"
            android:layout_height="200dp"
            android:layout_marginBottom="8dp"
            android:scaleType="centerCrop"
            android:background="#E0E0E0"
            tools:srcCompat="@tools:sample/backgrounds/scenic" />

        <Button
            android:id="@+id/btnCargarImagen"
            style="?attr/materialButtonOutlinedStyle"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            android:text="Seleccionar Imagen" />

        <Button
            android:id="@+id/btGuardar"
            android:layout_width="match_parent"
            android:layout_height="56dp"
            android:layout_marginTop="8dp"
            android:text="Guardar"
            android:textSize="16sp"
            android:textStyle="bold"
            app:cornerRadius="8dp" />

        <TextView
            android:id="@+id/tvMensaje"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text=""
            android:textColor="?android:attr/textColorSecondary"
            android:textSize="16sp" />

    </LinearLayout>
</ScrollView>